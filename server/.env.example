# Music server runtime config.
#
# Copy to `.env` and edit. Path values (LIBRARY_PATH, INGEST_PATH) resolve
# relative to the directory containing this .env file (i.e. `server/`).
# Absolute paths are used as-is.

SECRET_KEY=secret-key
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/?sslmode=disable

# Postgres credentials. Consumed by docker-compose.yml (it auto-loads this .env
# for ${...} substitution when you run `docker compose` from server/). Keep these
# in sync with the user:password embedded in DATABASE_URL above — Compose can't
# parse the URL to extract them.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Bind addresses (defaults shown).
# GRPC_ADDR=0.0.0.0:50051
# REST_ADDR=0.0.0.0:8080

# Optional gRPC TLS. Set GRPC_TLS=1 to serve gRPC over TLS; then GRPC_TLS_CERT
# and GRPC_TLS_KEY (PEM file paths, relative to server/ or absolute) are
# required. Clients must then use an https:// gRPC URL. Default off (plaintext).
# GRPC_TLS=0
# GRPC_TLS_CERT=tls/server.crt
# GRPC_TLS_KEY=tls/server.key

# Optional REST TLS (HTTPS). Set REST_TLS=1 to serve REST over TLS, reusing the
# same GRPC_TLS_CERT/GRPC_TLS_KEY above (both required). When on, REST binds
# HTTPS_PORT (default 8443) on REST_ADDR's host instead of the plaintext :8080,
# and clients must use an https:// REST URL. Default off (plaintext).
# REST_TLS=0
# HTTPS_PORT=8443

# Library + ingest paths (relative to server/).
LIBRARY_PATH=tmp/library
INGEST_PATH=tmp/ingest

# Primary display language. When merged duplicates carry multiple spellings
# (e.g. Korean `우기 ((여자)아이들)` + English `YUQI`), the spelling in this
# language is shown as the canonical artist/album name; the other spellings are
# preserved as aliases. Accepts a name or ISO code (English / en / eng).
# Default English. (A per-user setting later; an env var for now.)
# PRIMARY_LANGUAGE=English

# Metadata & Artwork (Phase 7).
# Write metadata edits back to file audio tags via lofty. Default off.
# WRITE_TAGS=0
# Auto-fetch album artwork from the Cover Art Archive. Default off.
# FETCH_ARTWORK=0
# Cache dir for fetched covers. Defaults to <LIBRARY_PATH>/.artwork.
# ARTWORK_PATH=tmp/artwork

# Follow notifications — real-time push (Phase 10, Firebase Cloud Messaging).
# When FCM_ENABLED=1, a new release by a followed artist is pushed to followers'
# registered devices (the client also polls as a fallback). Then FCM_PROJECT_ID
# (your Firebase project id) and FCM_CREDENTIALS (path to a Google
# service-account JSON key, relative to server/ or absolute) are both required.
# Default off.
# FCM_ENABLED=0
# FCM_PROJECT_ID=your-firebase-project-id
# FCM_CREDENTIALS=secrets/fcm-service-account.json

# Podcasts (optional). Discover shows via the iTunes Search API (no key) +
# optional PodcastIndex API, download episode audio to disk, and notify
# subscribers of new episodes. Enabled whenever a storage path resolves:
# PODCAST_PATH if set, else <LIBRARY_PATH>/Podcasts. Unset both → disabled.
# PODCAST_PATH=tmp/podcasts
# Feed refresh poller cadence (seconds). 0 disables the poller. Default 1800.
# PODCAST_REFRESH_INTERVAL_SECS=1800
# Default newest-N auto-download per show (0 = metadata only). Default 0.
# PODCAST_AUTO_DOWNLOAD_DEFAULT=0
# Optional PodcastIndex API creds for richer search (both required together;
# absent → iTunes-only). Get a key at https://api.podcastindex.org.
# PODCASTINDEX_API_KEY=your-podcastindex-key
# PODCASTINDEX_API_SECRET=your-podcastindex-secret

# Library-storage refresh job cadence (seconds). Each run does a light refresh
# (index new files, prune missing, recompute storage stats). 0 disables the
# periodic pass (a one-shot startup recompute still runs). Default 86400 (24h).
# STORAGE_REFRESH_SECS=86400

# Acoustic fingerprinting (Phase 12) — content-based "sounds like" radio.
# When FINGERPRINT_ENABLED=1, a background pass decodes each track and stores a
# similarity embedding, enabling true acoustic "sounds like" radio + the
# per-track / "Sounds like this" shelf. Off by default; when off the radio stays
# purely behavioral (artist/album/play-history based) and the server is unchanged.
# FINGERPRINT_ENABLED=0
# Optional ONNX audio-encoder model path (relative to server/ or absolute).
# When set AND the server is built with `--features onnx`, the learned encoder is
# used; unset → the pure-Rust DSP extractor (dsp-v1, no model file needed). A
# model change re-analyzes the library automatically.
# FINGERPRINT_MODEL=models/openl3.onnx
# Background analysis-pass cadence (seconds). 0 = run once on startup only.
# The pass is incremental (skips tracks whose file + model are unchanged).
# Default 21600 (6h).
# FINGERPRINT_INTERVAL_SECS=21600
# Concurrent analysis workers (decode + DSP/ONNX is CPU-heavy).
# Default min(4, cores-1).
# FINGERPRINT_CONCURRENCY=4

# Synced lyrics (Phase 15) — per-track synced (.lrc) + plain lyrics for the
# NowPlaying lyric panel. When LYRICS_ENABLED=1, each track is resolved from a
# sidecar `.lrc`, then embedded lyric tags, then LRCLIB (free, no API key),
# cached on disk under LYRICS_PATH (like artwork) and mirrored to the client for
# offline. Opening the panel also resolves on demand. Off by default; when off
# the server is unchanged and the panel shows "No lyrics available".
# LYRICS_ENABLED=0
# Allow the external provider (LRCLIB). Default on (when enabled); set 0 to
# restrict resolution to sidecar + embedded tags only (no outbound calls).
# LYRICS_FETCH=1
# External source id (lrclib is the only backend today).
# LYRICS_PROVIDER=lrclib
# Cache dir for resolved .lrc blobs (relative to server/ or absolute).
# Defaults to <LIBRARY_PATH>/.lyrics.
# LYRICS_PATH=tmp/lyrics
# Optional contact (URL or email) appended to the provider User-Agent, so
# LRCLIB can reach you — polite etiquette for a free community service.
# LYRICS_CONTACT=you@example.com
# Background resolve-pass cadence (seconds). 0 = run once on startup only.
# Incremental + polite (bounded per pass). Default 86400 (24h).
# LYRICS_INTERVAL_SECS=86400
# Concurrent resolve workers (network-bound; kept low + polite). Default 2.
# LYRICS_CONCURRENCY=2
# Embed resolved lyrics back into the audio file's tags via lofty (symmetric
# with WRITE_TAGS). Default off.
# WRITE_LYRICS=0

# Optional. Set to 1/true to start the admin UI.
# ENABLE_ADMIN_UI=0
